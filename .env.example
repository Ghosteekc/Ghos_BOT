# Telegram Bot Token from @BotFather
BOT_TOKEN=your_telegram_bot_token

# Clash Royale API key from https://developer.clashroyale.com
# Whitelist: только IP вашего VPS-прокси (не Railway)
CLASH_ROYALE_API_KEY=your_clash_royale_api_key

# Прямой доступ (локально) или VPS-прокси (Railway + статический IP на VPS)
# Локально: https://api.clashroyale.com/v1
# Railway:  http://YOUR_VPS_IP/v1  (см. scripts/cr-proxy/README.md)
CLASH_ROYALE_API_BASE=https://api.clashroyale.com/v1

# Секрет для VPS nginx (тот же, что в cr-proxy.conf). Пусто — если API напрямую.
CLASH_ROYALE_PROXY_SECRET=

# Database URL (SQLite by default, use PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./cr_bot.db

# Subscription settings
TRIAL_DAYS=30
SUBSCRIPTION_PRICE_STARS=0

# Mini App URL on Vercel (HTTPS, for BotFather Menu Button and WEBAPP_URL)
WEBAPP_URL=https://your-project.vercel.app

# Support Telegram username (without @)
SUPPORT_USERNAME=your_support_username

# Frontend API base URL for Vite build (leave empty for same-origin / Railway)
# VITE_API_URL=http://localhost:8080

# API server (FastAPI)
API_HOST=0.0.0.0
API_PORT=8080

# Optional: admin Telegram IDs for /admin_sub and /sync_now (comma-separated)
ADMIN_TELEGRAM_ID=123456789
ADMIN_TELEGRAM_IDS=123456789,987654321

# Optional: sync interval in minutes
SYNC_INTERVAL_MINUTES=60
